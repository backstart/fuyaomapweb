# 生产环境构建回退值；正式部署建议由 app-config.js 统一覆盖。
VITE_API_BASE_URL=/api
# 生产环境通常由前端服务器 Nginx 通过 /tiles/ 提供本地 PMTiles 文件。
VITE_PMTILES_URL=/tiles/city.pmtiles
# 优先复用构建期产出的标准 style，失败时再回退到运行时动态 style 构造。
VITE_MAP_STYLE_URL=/map-resources/styles/amap-like.json
# 可选：生产可由 app-config.js 或构建环境注入访客 IP 定位接口；未配置时会快速回退到中山市。
VITE_MAP_IP_LOCATE_URL=
