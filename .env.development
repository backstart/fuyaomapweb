# 本地开发统一走同源 /api，由 Vite 代理到本地后端，避免浏览器 CORS。
VITE_API_BASE_URL=/api
# Vite 开发代理的后端目标地址。
DEV_API_PROXY_TARGET=http://localhost:7165
# 本地开发回退配置：请改成你当前可访问的 PMTiles 地址。
VITE_PMTILES_URL=/tiles/city.pmtiles
# 优先复用构建期产出的标准 style，失败时再回退到运行时动态 style 构造。
VITE_MAP_STYLE_URL=/map-resources/styles/amap-like.json
# 可选：内部如有访客 IP 定位接口，可在这里配置；未配置时会快速回退到中山市。
VITE_MAP_IP_LOCATE_URL=
